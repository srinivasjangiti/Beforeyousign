# NVIDIA NIM API – https://docs.api.nvidia.com
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_REQUEST_TIMEOUT_MS=45000

# Other AI Providers
GOOGLE_AI_API_KEY=your_google_ai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Application Configuration
NEXT_PUBLIC_APP_NAME=BeforeYouSign
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_MAX_FILE_SIZE=10485760
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Analysis Configuration
ANALYZE_MAX_RETRIES=1
ANALYZE_MAX_PROMPT_CHARS=100000
ANALYZE_MAX_OUTPUT_TOKENS=4096

# ===========================
# Authentication (Clerk)
# ===========================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key
CLERK_SECRET_KEY=your_clerk_secret_key

# ===========================
# Authentication (NextAuth.js - Legacy/Alternative)
# ===========================
# Generate a random secret: openssl rand -base64 32
AUTH_SECRET=your_nextauth_secret_here

# OAuth Providers (Optional)
AUTH_GITHUB_ID=your_github_client_id
AUTH_GITHUB_SECRET=your_github_client_secret
AUTH_GOOGLE_ID=your_google_client_id
AUTH_GOOGLE_SECRET=your_google_client_secret

# ===========================
# Database (Prisma)
# ===========================
# PostgreSQL / Supabase / MongoDB
DATABASE_URL=your_database_connection_string
DIRECT_URL=your_direct_database_connection_string

# ===========================
# Supabase Configuration
# ===========================
# Get from: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ===========================
# Third-Party Integrations
# ===========================
SALESFORCE_CLIENT_ID=your_salesforce_client_id
GOOGLE_CLIENT_ID=your_google_client_id
SLACK_CLIENT_ID=your_slack_client_id

# ===========================
# Email Service (For Production)
# ===========================
# SendGrid, Mailgun, or Resend
EMAIL_FROM=noreply@beforeyousign.com
SENDGRID_API_KEY=your_sendgrid_key

# ===========================
# Analytics & Error Tracking (For Production)
# ===========================
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn
